  "strictRejectRules": [
    {
      "ruleId": "SR-001",
      "category": "生鲜易腐商品",
      "productKeywords": ["生鲜", "水果", "蔬菜", "肉类", "海鲜", "水产", "冷冻", "冷藏", "鲜奶", "酸奶", "蛋糕", "熟食"],
      "synonyms": ["吃的", "食物", "食品", "刺身", "三文鱼", "牛排", "冰鲜", "保鲜", "速冻", "生食"],
      "examples": ["买的是吃的", "这是食物不能退吗"],
      "matchType": "semantic",
      "reason": "根据《消费者权益保护法》，鲜活易腐商品不适用七天无理由退货",
      "exception": "收到时已损坏腐烂或变质，需提供开箱视频/照片作为凭证",
      "autoReject": true
    },
    {
      "ruleId": "SR-002",
      "category": "数字化商品",
      "productKeywords": ["激活码", "序列号", "充值卡", "点卡", "兑换码", "电子券", "虚拟商品", "会员", "课程", "电子书"],
      "synonyms": ["key", "cdkey", "数字版", "在线课程", "网课", "充值码", "优惠券码"],
      "examples": ["买了一个激活码", "是电子版的"],
      "matchType": "semantic",
      "reason": "数字化商品一经交付即视为消费完成，不支持退货",
      "exception": "激活码/序列号未使用且可验证未激活状态",
      "autoReject": true
    },
    {
      "ruleId": "SR-003",
      "category": "个人卫生用品",
      "productKeywords": ["内衣", "内裤", "文胸", "袜子", "口罩", "耳塞", "牙刷", "剃须刀", "私密护理"],
      "synonyms": ["贴身衣物", "内搭", "bra", "bra", "贴身", "个人护理", "电动牙刷头"],
      "examples": ["买的内衣不合适", "穿过的能退吗"],
      "matchType": "semantic",
      "reason": "个人卫生用品拆封后不予退货，保障消费者健康安全",
      "exception": "商品未拆封包装完好，且不属于质量问题",
      "autoReject": true
    },
    {
      "ruleId": "SR-004",
      "category": "定制类商品",
      "productKeywords": ["定制", "订制", "刻字", "DIY", "个性化", "定制款", "来图", "专属"],
      "synonyms": ["定制化", "私人订制", "定做", "刻名字", "专属定制", "个性定制"],
      "examples": ["刻了名字的", "按照我的要求做的"],
      "matchType": "semantic",
      "reason": "定制类商品具有唯一性，无法二次销售，不支持退货",
      "exception": "商品本身存在质量问题或与定制要求不符",
      "autoReject": true
    },
    {
      "ruleId": "SR-005",
      "category": "已使用的消耗品",
      "productKeywords": ["化妆品", "护肤品", "香水", "精油", "保健品", "食品", "茶叶", "咖啡", "耗材", "墨盒", "硒鼓", "胶卷"],
      "synonyms": ["美妆", "护肤", "面霜", "口红", "粉底", "用过的", "拆开的", "开封"],
      "examples": ["用了一次不合适", "打开试了一下"],
      "matchType": "semantic",
      "reason": "消耗品一经使用即影响二次销售，不支持退货",
      "exception": "未拆封未使用，且签收后7天内",
      "autoReject": false,
      "condition": "需人工判断拆封状态"
    },
    {
      "ruleId": "SR-006",
      "category": "限时/抢购商品",
      "productKeywords": ["秒杀", "限时", "闪购", "特价", "清仓", "尾货", "样机"],
      "synonyms": ["抢购", "优惠抢", "秒拍", "限量", "特卖", "打折清"],
      "examples": ["秒杀抢到的", "特价买的"],
      "matchType": "semantic",
      "reason": "明确标注不支持退货的限时促销商品不予退货",
      "exception": "商品存在质量问题",
      "autoReject": false,
      "condition": "需检查商品详情页是否标注不支持七天无理由退货"
    }
  ],

  "receiptDayThresholds": {
    "unconditional": { "days": 7, "description": "七天无理由退货期，符合条件自动通过" },
    "conditional": { "days": 15, "description": "7-15天仅接受质量问题/描述不符类退货" },
    "strict": { "days": 30, "description": "15-30天需严格审查，仅重大质量问题可能通过" },
    "reject": { "days": 999, "description": "超过30天一律拒绝（除非法律另有规定）" }
