{
  "version": "2.0",
  "description": "退货审核规则知识库 v2.0 — 支持混合检索（精确+同义+模糊+向量语义）",

  "autoApproveRules": [
    {
      "ruleId": "AA-001",
      "condition": "七天无理由退货且在有效期内",
      "receiptDaysMax": 7,
      "allowedReasons": ["七天无理由", "不想要了", "买错了", "拍错了", "多拍", "不需要了", "不喜欢"],
      "synonyms": ["无理由", "7天无理由", "七日无理由", "不想要", "买错", "拍多", "买多", "下错单", "不想要这个", "想退"],
      "examples": ["买回来不喜欢", "用不上", "冲动消费了", "和想象中不一样", "用了一次不合适", "打开试了一下不喜欢"],
      "matchType": "semantic",
      "requirements": ["商品未经使用保持原状", "配件赠品包装完整", "不属于严格拒绝类商品"]
    },
    {
      "ruleId": "AA-002",
      "condition": "商品质量问题且有凭证",
      "receiptDaysMax": 15,
      "allowedReasons": ["质量问题", "有瑕疵", "破损", "坏了", "不能用了", "功能异常", "外观缺陷"],
      "synonyms": ["质量不行", "做工差", "有毛病", "坏的", "次品", "残次品", "开线", "掉色", "脱落", "做工太差", "线头", "质量太差了", "做工粗糙"],
      "examples": ["收到就是坏的", "用了两天就坏了", "屏幕有裂痕", "按钮按不动", "做工太差了线头到处是", "收到发现是坏的"],
      "matchType": "semantic",
      "requirements": ["提供清晰的商品问题照片或视频", "问题非人为损坏"]
    },
    {
      "ruleId": "AA-003",
      "condition": "商品与描述不符",
      "receiptDaysMax": 15,
      "allowedReasons": ["与描述不符", "颜色不对", "尺寸不对", "规格不对", "发错货", "少件", "漏发"],
      "synonyms": ["图文不符", "和图片不一样", "色差大", "尺寸偏差", "发错了", "少了配件", "颜色不对", "和图片差太多", "颜色差别太大", "收到的不一样"],
      "examples": ["实物颜色和网上完全不一样", "买的L码发的M码", "少了一个充电器", "颜色和网页图片差太多了", "收到的东西和图片不一样"],
      "matchType": "semantic",
      "requirements": ["提供商品实物照片与页面描述对比", "型号规格颜色与订单记录不一致"]
    },
    {
      "ruleId": "AA-004",
      "condition": "物流损坏",
      "receiptDaysMax": 3,
      "allowedReasons": ["物流损坏", "快递破损", "包装破损", "运输损坏"],
      "synonyms": ["快递摔坏了", "盒子烂了", "运输中碰坏了", "快递暴力", "包装坏了", "盒子破了", "快递弄坏了", "收到就破了"],
      "examples": ["收到时包装已经烂了", "快递把东西摔变形了", "盒子完全烂了里面也坏了", "包装都破了"],
      "matchType": "semantic",
      "requirements": ["提供开箱视频或快递面单+破损照片", "在签收后3天内反馈"]
    }
